package pl.edu.atar.universityrecruitment.rules.intermediate.upper.twosetsofrulessalienceactivationgrouplockonactivemodify

import pl.edu.atar.universityrecruitment.Candidate;

// Informatyka
rule "Exam Qualification / Informatyka (two_sets_of_rules_salience_activation-group_lock-on-active_MODIFY)"
    dialect "java"
    salience 100
    activation-group "group-1"
    lock-on-active true
    when
        $uc : Candidate(examResult > 100, fieldOfStudy == "Informatyka")
    then
        modify($uc) {
            setAdmission(true),
            setQualificationType("Exam qualification")
        }
        $uc.appendLogger("Agenda '" + drools.getKieRuntime().getAgenda().toString() + "' got focus!");
        $uc.appendLogger("Rule '" + drools.getRule().getName() + "' from package '" + drools.getRule().getPackageName() + "' fired!");
end

// Automatyka i robotyka
rule "Exam Qualification / Automatyka i robotyka (two_sets_of_rules_salience_activation-group_lock-on-active_MODIFY)"
    dialect "java"
    salience 100
    activation-group "group-1"
    lock-on-active true
    when
        $uc : Candidate(examResult > 60, fieldOfStudy == "Automatyka i robotyka")
    then
        modify($uc) {
            setAdmission(true),
