package pl.edu.atar.universityrecruitment.rules.intermediate.upper.twosetsofrulessalienceactivationgrouplockonactivemodify

import pl.edu.atar.universityrecruitment.Candidate;

// Kwalifikacja olimpijska
rule "Olympic qualification (two_sets_of_rules_salience_activation-group_lock-on-active_MODIFY)"
    dialect "java"
    salience 200
    activation-group "group-1"
    lock-on-active true
    when
        $uc : Candidate(olympicFinalist == true)
    then
        modify($uc) {
            setAdmission(true),
            setQualificationType("Olympic qualification")
        }
        $uc.appendLogger("Agenda '" + drools.getKieRuntime().getAgenda().toString() + "' got focus!");
        $uc.appendLogger("Rule '" + drools.getRule().getName() + "' from package '" + drools.getRule().getPackageName() + "' fired!");
end