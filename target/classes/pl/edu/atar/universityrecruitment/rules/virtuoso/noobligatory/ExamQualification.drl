// Elektrotechnika
rule "Exam Qualification / Elektrotechnika (exam_result_calculation)"
    dialect "java"
    salience 250
    when
        $uc : Candidate(fieldOfStudy == "Elektrotechnika", examResult >= 80.0)
    then
        $uc.appendLogger("Total candidate exam result = " + $uc.getExamResult() + ". Minimum required exam result 80.0D");
        $uc.setAdmission(true);
        $uc.setQualificationType("Exam qualification");
        $uc.appendLogger("Agenda '" + drools.getKieRuntime().getAgenda().toString() + "' got focus!");
        $uc.appendLogger("Rule '" + drools.getRule().getName() + "' from package '" + drools.getRule().getPackageName() + "' fired!");
end

