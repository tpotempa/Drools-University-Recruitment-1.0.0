package pl.edu.atar.universityrecruitment.rules.intermediate.middle.twosetsofrulessaliencenoloopmodify

import pl.edu.atar.universityrecruitment.Candidate;

// Informatyka
rule "Exam Qualification / Informatyka (two_sets_of_rules_salience_no-loop_MODIFY)"
    dialect "java"
    salience 100
    no-loop true
    when
        $uc : Candidate(examResult > 100, fieldOfStudy == "Informatyka", counter < 10)
    then
        modify($uc) {
            setAdmission(true),
            setQualificationType("Exam qualification"),
            incrementCounter()
        }
        $uc.appendLogger("Agenda '" + drools.getKieRuntime().getAgenda().toString() + "' got focus!");
        $uc.appendLogger("Rule '" + drools.getRule().getName() + "' from package '" + drools.getRule().getPackageName() + "' fired!");
end

